NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

ADMIN_PASSWORD=change-me
# Required in production. Must be at least 32 characters.
# Generate with: openssl rand -hex 32  (or)  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=generate-a-long-random-string-at-least-32-chars

# Optional. Comma-separated list of additional origins allowed to call Server Actions
# (in addition to the request's same-origin). Useful behind reverse proxies / preview deploys.
# Example: https://itleague.example.com,https://preview.itleague.example.com
SERVER_ACTIONS_ALLOWED_ORIGINS=
